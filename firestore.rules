rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email == "youractualadminemail@gmail.com")
        || (request.auth.token.role != null && request.auth.token.role == "admin")
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    function isDriver() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/drivers/$(request.auth.uid)).data.role == "driver";
    }

    function isUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "user";
    }

    function validBookingStatus(status) {
      return status in ["searching", "accepted", "in-progress", "completed", "cancelled"];
    }

    function validTripStatus(status) {
      return status in ["accepted", "in-progress", "completed", "cancelled"];
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
    }

    match /drivers/{driverId} {
      // Driver records are readable by the driver owner, admin, and authenticated users in tracking contexts.
      allow read: if request.auth.uid == driverId || isAdmin() || isUser() || isDriver();
      allow create: if request.auth.uid == driverId;
      allow update: if request.auth.uid == driverId || isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userPhone is string
        && request.resource.data.patientName is string
        && request.resource.data.emergency is string
        && validBookingStatus(request.resource.data.status)
        && request.resource.data.requestedAt is timestamp
        && request.resource.data.pickupLocation.latitude is number
        && request.resource.data.pickupLocation.longitude is number;

      allow read: if isAdmin()
        || (resource.data.driverId == request.auth.uid)
        || (resource.data.userId == request.auth.uid)
        || (isDriver() && resource.data.status == "searching");

      allow update: if isAdmin()
        || (resource.data.driverId == request.auth.uid)
        || (resource.data.userId == request.auth.uid);

      allow delete: if isAdmin();
    }

    match /trips/{tripId} {
      allow create: if isSignedIn()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.userPhone is string
        && validTripStatus(request.resource.data.status)
        && request.resource.data.pickupLocation.latitude is number
        && request.resource.data.pickupLocation.longitude is number;

      allow read: if isAdmin()
        || (resource.data.driverId == request.auth.uid)
        || (resource.data.userId == request.auth.uid);

      allow update: if isAdmin() || (resource.data.driverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /driverNotifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.driverId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isSignedIn() && resource.data.driverId == request.auth.uid;
      allow delete: if isAdmin() || (resource.data.driverId == request.auth.uid);
    }
  }
}
